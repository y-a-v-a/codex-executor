{
  "permissions": {
    "allow": [
      "WebFetch(domain:developers.openai.com)",
      "Bash"
    ]
  },
  "hooks": {
    "SubagentStart": [
      {
        "matcher": "codex-executor",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Starting Codex executor agent...' >&2"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "codex-executor",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Codex executor agent finished.' >&2"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "./scripts/validate-codex-command.sh"
          }
        ]
      }
    ]
  }
}
